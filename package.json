{
  "name": "growth-record",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker and Pages project for a personal growth record system.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "desktop:dev": "cd apps/desktop && tauri dev",
    "desktop:build": "cd apps/desktop && tauri build",
    "desktop:build:mac": "cd apps/desktop && tauri build --bundles dmg,app",
    "desktop:build:windows": "cd apps/desktop && tauri build --bundles msi,nsis",
    "mobile:flutter": "cd apps/mobile && flutter",
    "mobile:build:android": "cd apps/mobile && flutter build apk --release --dart-define=GROWTH_RECORD_WEB_URL=https://growth.ai-gate.work",
    "mobile:build:ios": "cd apps/mobile && flutter build ios --release --no-codesign --dart-define=GROWTH_RECORD_WEB_URL=https://growth.ai-gate.work",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260507.0",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.0.8",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8",
    "wrangler": "^4.50.0"
  }
}
